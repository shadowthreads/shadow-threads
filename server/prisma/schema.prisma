// Shadow Threads 数据库 Schema
// 使用 Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 用户相关
// ============================================

model User {
  id    String  @id @default(uuid())
  email String? @unique
  name  String?

  // 本地用户可以没有邮箱，用设备标识
  deviceId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联
  apiKeys    UserApiKey[]
  subthreads Subthread[]
  settings   UserSettings?

  // ✅ StateSnapshot 反向关系（修复 Prisma P1012）
  stateSnapshots StateSnapshot[]

  @@index([email])
  @@index([deviceId])
}

model UserSettings {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 默认 LLM 提供商
  defaultProvider LLMProvider @default(OPENAI)

  // UI 偏好
  theme    String @default("auto") // auto, light, dark
  language String @default("zh-CN")

  // 功能开关
  autoSummarize Boolean @default(true)
  saveHistory   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 用户的 API Key 存储（加密存储）
model UserApiKey {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider LLMProvider

  // API Key（加密存储）
  encryptedKey String

  // 元数据
  label     String? // 用户自定义标签
  isDefault Boolean   @default(false)
  isValid   Boolean   @default(true)
  lastUsed  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, provider, label])
  @@index([userId, provider])
}

// ============================================
// LLM 提供商枚举
// ============================================

enum LLMProvider {
  OPENAI // ChatGPT
  ANTHROPIC // Claude
  GOOGLE // Gemini
  GROQ // Groq
  OLLAMA // 本地 Ollama
  DEEPSEEK // Deepseek
  CUSTOM // 自定义 API
}

// ============================================
// 子线程相关
// ============================================

// 主对话上下文（来源）
model SourceContext {
  id String @id @default(uuid())

  // 来源平台
  platform String // chatgpt, claude, gemini, etc.

  // 原始对话信息
  conversationId  String // 平台的对话 ID
  conversationUrl String? // 对话 URL

  // 原始消息信息
  messageId   String // 平台的消息 ID
  messageRole String // user, assistant
  messageText String @db.Text // 完整消息文本

  // 用户选中的片段
  selectionText  String @db.Text
  selectionStart Int? // 选中起始位置
  selectionEnd   Int? // 选中结束位置

  // ✅ PR-B2：Context L1 元信息（窗口化上下文的 meta）
  contextMeta Json?

  createdAt DateTime @default(now())

  // 关联
  subthread Subthread?

  @@index([platform, conversationId])
  @@index([platform, messageId])
}

// 影子子线程
model Subthread {
  id String @id @default(uuid())

  // 所属用户
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 来源上下文
  sourceContextId String        @unique
  sourceContext   SourceContext @relation(fields: [sourceContextId], references: [id], onDelete: Cascade)

  // 使用的 LLM
  provider LLMProvider
  model    String // 具体模型，如 gpt-4, claude-3-opus

  // 子线程标题（可自动生成）
  title String?

  // 状态
  status SubthreadStatus @default(ACTIVE)

  // 上下文摘要（用于长对话压缩）
  summary String? @db.Text

  // 统计
  messageCount Int @default(0)
  tokenCount   Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联
  messages SubthreadMessage[]

  // ✅ StateSnapshot 反向关系（修复 Prisma P1012）
  stateSnapshots StateSnapshot[]

  @@index([userId, createdAt])
  @@index([userId, status])
}

enum SubthreadStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

// 子线程消息
model SubthreadMessage {
  id String @id @default(uuid())

  subthreadId String
  subthread   Subthread @relation(fields: [subthreadId], references: [id], onDelete: Cascade)

  // 消息内容
  role    MessageRole
  content String      @db.Text

  // Token 统计
  promptTokens     Int?
  completionTokens Int?

  // 元数据
  model        String? // 使用的模型
  finishReason String? // stop, length, etc.

  // 错误信息（如果有）
  error String?

  createdAt DateTime @default(now())

  @@index([subthreadId, createdAt])
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
}

// ============================================
// StateSnapshot（思考状态库 v1）
// ============================================

model StateSnapshot {
  id String @id @default(uuid())

  // 归属用户
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 来源子线程（v1 可选）
  subthreadId String?
  subthread   Subthread? @relation(fields: [subthreadId], references: [id], onDelete: SetNull)

  // 核心：StateSnapshot v1 JSON
  snapshot Json

  // 版本控制（仍然固定 v1，语义不变）
  version String

  // ========= 新增：状态演化链（不会影响现有逻辑） =========

  /// 整条状态链的根（第一版 snapshot）
  rootId String?

  /// 上一个 snapshot（用于回溯）
  parentId String?

  /// 第几次演化（0 = 初始）
  rev Int @default(0)

  /// 自引用关系（可选但强烈推荐）
  parent   StateSnapshot?  @relation("StateSnapshotLineage", fields: [parentId], references: [id])
  children StateSnapshot[] @relation("StateSnapshotLineage")

  // =========================================================

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([subthreadId])
  @@index([rootId])
  @@index([parentId])
}

// ============================================
// 系统配置
// ============================================

model SystemConfig {
  key   String @id
  value String @db.Text

  updatedAt DateTime @updatedAt
}